{
  "name": "snapcal",
  "version": "1.0.0",
  "description": "SnapCal - AI-powered food tracking. Snap a photo, know your food.",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:init": "node -e \"import('./src/db/index.js')\"",
    "test": "node --test tests/**/*.test.js",
    "test:api": "node --test tests/api.test.js",
    "test:entries": "curl -s http://localhost:3001/entries | jq"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "better-sqlite3": "^12.6.2",
    "hono": "^4.7.5",
    "openai": "^6.25.0",
    "zod": "^3.24.2"
  }
}

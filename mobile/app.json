{
  "expo": {
    "name": "SnapCal",
    "slug": "snapcal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "snapcal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#22c55e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.snapcal.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow SnapCal to access your camera to photograph food for calorie tracking.",
        "NSPhotoLibraryUsageDescription": "Allow SnapCal to access your photo library to select food photos for tracking.",
        "NSPhotoLibraryAddUsageDescription": "Allow SnapCal to save food photos to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#22c55e"
      },
      "package": "com.snapcal.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FoodLog to access your camera to photograph food for calorie tracking."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FoodLog to access your photo library to select food photos for tracking."
        }
      ],
      "expo-asset",
      "expo-barcode-scanner",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "snapcal"
      }
    }
  }
}
